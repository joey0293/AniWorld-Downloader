# ==============================
# General Application Settings
# ==============================

# Where downloads are saved (relative or absolute path).
# Example: Downloads
ANIWORLD_DOWNLOAD_PATH=Downloads

# Folder used for app data/cache/config (relative to the download path).
# Example: .aniworld
ANIWORLD_INSTALL_FOLDER=.aniworld

# Debug logging
# 0 = off, 1 = on
ANIWORLD_DEBUG_MODE=0


# ==============================
# Anime & Language Preferences
# ==============================

# Preferred audio/sub language preset.
# Options: German Dub | English Sub | German Sub | English Dub
ANIWORLD_LANGUAGE="German Dub"

# Output file naming template.
# Common placeholders: {title} {year} {imdbid} {season} {episode}
# Example: groups by show + year, then season, then uses SxxExx naming
# (e.g. `Highschool DxD (2012) [imdbid-tt1759761]/Season 1/Highschool DxD S01E01.mkv`).
ANIWORLD_NAMING_TEMPLATE="{title} ({year}) [imdbid-{imdbid}]/Season {season}/{title} S{season}E{episode}.mkv"


# ==============================
# Provider & Streaming Options
# ==============================

# Streaming provider to use.
# Options: Filemoon | Vidmoly | VOE | LoadX | Luluvdo | Doodstream | SpeedFiles | Streamtape | Vidoza
ANIWORLD_PROVIDER=VOE

# Pick a random anime instead of the one you pass in.
# 0 = off, 1 = on
ANIWORLD_RANDOM_ANIME=0

# Enable AniSkip (auto skip intro/outro) if skip times are available.
# 0 = off, 1 = on
ANIWORLD_ANISKIP=0


# ==============================
# Player Integration
# ==============================

# Which player Syncplay should use.
# 0 = mpv (cross-platform)
# 1 = IINA (macOS only; requires IINA installed)
ANIWORLD_USE_IINA=1


# ==============================
# Syncplay Settings (auto-generated if left empty)
# ==============================

# Syncplay server host:port
# Default: syncplay.pl:8998
# Other ports: syncplay.pl:8995 / :8996 / :8997 / :8999
ANIWORLD_SYNCPLAY_HOST=

# Room to join.
# If ANIWORLD_SYNCPLAY_ROOM is empty, the app generates it from the episode name:
# - If ANIWORLD_SYNCPLAY_PASSWORD is NOT set:
#     AniWorld-Highschool_DxD_S01E01
# - If ANIWORLD_SYNCPLAY_PASSWORD IS set (example: "beans"), the room becomes a SHA256 hash:
#     plain: AniWorld-Highschool_DxD_S01E01-beans
#     room:  AniWorld-53de358cf5b5fe716f78747bad1c874ed23147509bbaf540d02aac31f4f35656
#
# Tip: setting ANIWORLD_SYNCPLAY_PASSWORD changes the generated room name, so only people with the same
# password end up in the same room (unless you manually set ANIWORLD_SYNCPLAY_ROOM).
ANIWORLD_SYNCPLAY_ROOM=

# Your name shown in Syncplay.
# If empty, it will use your system username.
# Example: phoenixthrush
ANIWORLD_SYNCPLAY_USERNAME=

# Optional. Used only when ANIWORLD_SYNCPLAY_ROOM is empty (see above).
# Setting this WILL change the generated room name.
ANIWORLD_SYNCPLAY_PASSWORD=


# ==============================
# FFmpeg & Encoding Settings
# ==============================

# Video codec behavior.
# copy = no re-encode (fastest, keeps original)
# h264 / h265 / av1 = re-encode using FFmpeg (slower, smaller files depending on settings)
ANIWORLD_VIDEO_CODEC=copy
