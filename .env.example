# -----------------
#   Configuration
# -----------------

# Default folder where downloads will be saved
# TODO: allow absolute paths
ANIWORLD_DOWNLOAD_PATH=Downloads

# Default language selection for anime
# Options: "German Dub", "English Sub", "German Sub", "English Dub"
ANIWORLD_LANGUAGE=German Dub

# Installation folder for dependencies (default is user home)
ANIWORLD_INSTALL_FOLDER=.aniworld

# Naming template for downloaded episodes
# Variables: {title}, {year}, {imdbid}, {season}, {episode}
# Example output: "Highschool DxD (2012-2018) [imdbid-tt2230051]/Season 01/Highschool DxD S01E01.mkv"
ANIWORLD_NAMING_TEMPLATE="{title} ({year}) [imdbid-{imdbid}]/Season {season}/{title} S{season}E{episode}.mkv"

# Default streaming/provider service
# Options: "Filemoon", "Vidmoly", "VOE", "LoadX", "Luluvdo", "Doodstream", "SpeedFiles", "Streamtape", "Vidoza"
ANIWORLD_PROVIDER=VOE

# Select random anime
ANIWORLD_RANDOM_ANIME=0

# Use aniskip
ANIWORLD_USE_ANISKIP=0

# Use IINA on macOS instead of mpv
ANIWORLD_USE_IINA=1
